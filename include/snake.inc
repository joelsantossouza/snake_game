%define MAP_ROW_SIZE			41
%define MAP_COL_SIZE			20
%assign MAP_SIZE				MAP_ROW_SIZE * MAP_COL_SIZE
%assign MAP_WALKABLE_SIZE		(MAP_ROW_SIZE - 3) * (MAP_COL_SIZE - 2)
%assign MAP_WALKABLE_FIRST		MAP_ROW_SIZE + 1

%define PLAYER_MAX_LENGTH		MAP_WALKABLE_SIZE

%define GAMEPLAY_DELAY_MIN_MS	0
%assign GAMEPLAY_DELAY_MIN_NS	GAMEPLAY_DELAY_MIN_MS * 1000000
%define GAMEPLAY_DELAY_MAX_MS	100
%assign GAMEPLAY_DELAY_MAX_NS	GAMEPLAY_DELAY_MAX_MS * 1000000
%assign GAMEPLAY_DELAY_STEP_NS	(GAMEPLAY_DELAY_MAX_NS - GAMEPLAY_DELAY_MIN_NS) / MAP_WALKABLE_SIZE

%define NEWLINE					0x0A
